generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum SessionStatus {
  IN_PROGRESS
  PROCESSING
  COMPLETED
  SUMMARY_FAILED
}

enum SessionInputType {
  VOICE
  MANUAL
}

enum CompanionMode {
  THINK_WITH_ME
  REFLECT
  JOURNAL_QUIETLY
}

enum SessionTurnRole {
  USER
  ASSISTANT
}

enum SessionTurnStatus {
  STREAMING
  FINAL
}

enum ProfileMemoryKind {
  IDENTITY
  PREFERENCE
  GOAL
  THEME
  RELATIONSHIP
  ROUTINE
  EMOTION
}

model JournalSession {
  id                 String           @id @default(cuid())
  startedAt          DateTime
  endedAt            DateTime
  entryDate          DateTime         @default(now())
  inputType          SessionInputType @default(VOICE)
  mode               CompanionMode    @default(THINK_WITH_ME)
  status             SessionStatus    @default(PROCESSING)
  turnCount          Int
  transcriptRetained Boolean          @default(true)
  processingError    String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  turns              SessionTurn[]
  tasks              Task[]
  summary            SessionSummary?
  memoryItems        ProfileMemory[]

  userId             String
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model SessionTurn {
  id         String            @id @default(cuid())
  sessionId  String
  session    JournalSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  orderIndex Int
  role       SessionTurnRole
  text       String
  status     SessionTurnStatus
  createdAt  DateTime          @default(now())

  @@index([sessionId, orderIndex])
}

model SessionSummary {
  id                  String         @id @default(cuid())
  sessionId           String         @unique
  session             JournalSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  title               String         @default("Untitled session")
  summary             String
  keyThemesJson       String
  rapidLogBulletsJson String         @default("[]")
  mood                String
  patternSummary      String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @default(now()) @updatedAt
}

model Task {
  id         String         @id @default(cuid())
  sessionId  String
  session    JournalSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  content    String
  completed  Boolean        @default(false)
  orderIndex Int
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([sessionId, orderIndex])
  @@index([completed, updatedAt])
}

model ProfileMemory {
  id              String            @id @default(cuid())
  kind            ProfileMemoryKind
  content         String
  sourceSessionId String?
  sourceSession   JournalSession?   @relation(fields: [sourceSessionId], references: [id], onDelete: SetNull)
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastSeenAt      DateTime
  seenCount       Int               @default(1)
  weight          Float             @default(1.0)
  pinned          Boolean           @default(false)
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([userId, kind, content])
  @@index([userId, active, weight, lastSeenAt])
}

model ProfileSnapshot {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── AUTHENTICATION MODELS ──────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[] // NextAuth sessions

  // Preferences
  voicePreference String @default("marin")

  // Custom relations
  journalSessions JournalSession[]
  memories        ProfileMemory[]
  snapshot        ProfileSnapshot?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
